---
const buildTime = new Date().toLocaleString("ko-KR", {
  timeZone: "Asia/Seoul",
  dateStyle: "medium",
  timeStyle: "short",
});
const ORG_URL = "https://github.com/Bit-Unity15th-MultiplayGameProjects";
---

<footer
  style="border-top:1px solid var(--border);padding:18px 24px;font-family:var(--mono);font-size:11px;color:var(--fg-3);"
>
  <div
    style="max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;"
  >
    <span>Last build · <time>{buildTime}</time></span>
    <span>
      <a
        href={ORG_URL}
        target="_blank"
        rel="noopener"
        style="color:var(--fg-3);text-decoration:none;"
        onmouseover="this.style.color='var(--fg-1)'"
        onmouseout="this.style.color='var(--fg-3)'"
      >
        Bit-Unity15th-MultiplayGameProjects ↗
      </a>
    </span>
  </div>
</footer>
