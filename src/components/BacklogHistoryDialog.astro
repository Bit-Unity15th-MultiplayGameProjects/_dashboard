---
import AgeBadge from "./AgeBadge.astro";
import type { BacklogItemWithAge, ResolvedItem } from "../lib/reports";

/**
 * Backlog 이력 모달.
 * - 네이티브 `<dialog>` 사용 (focus trap / ESC / backdrop 자동).
 * - 상단: 현재 carry-over (latest report 의 backlog + age)
 * - 하단: 누적 resolved 목록
 */
interface Props {
  project: string;
  carryOver: BacklogItemWithAge[];
  resolved: ResolvedItem[];
}
const { project, carryOver, resolved } = Astro.props;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("ko-KR", {
    timeZone: "Asia/Seoul",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });
}

const carrySorted = [...carryOver].sort((a, b) => b.age - a.age);
---

<dialog
  id="backlog-history-dialog"
  style="width:min(92vw, 640px);max-height:80vh;padding:0;border:1px solid var(--border);border-radius:6px;background:var(--bg-1);color:var(--fg-1);font-family:var(--sans);"
>
  <div
    style="display:flex;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--bg-1);"
  >
    <div>
      <h3
        style="margin:0;font-size:14px;font-weight:600;color:var(--fg-1);"
      >
        Backlog History
      </h3>
      <p
        style="margin:2px 0 0;font-family:var(--mono);font-size:11px;color:var(--fg-3);"
      >
        {project} · 누적 {carryOver.length} · 해결 {resolved.length}
      </p>
    </div>
    <button
      type="button"
      data-close-backlog
      aria-label="닫기"
      style="margin-left:auto;background:transparent;border:none;font-family:var(--mono);font-size:18px;color:var(--fg-3);cursor:pointer;padding:4px 8px;border-radius:3px;"
    >×</button>
  </div>

  <div style="padding:16px 20px;overflow-y:auto;max-height:calc(80vh - 64px);">
    <div style="margin-bottom:18px;">
      <span
        style="font-family:var(--mono);font-size:10px;color:var(--fg-3);letter-spacing:0.08em;text-transform:uppercase;"
        >carry-over · {carryOver.length}</span
      >
      {
        carrySorted.length === 0 ? (
          <p
            style="margin:8px 0 0;font-size:12.5px;color:var(--fg-3);font-style:italic;"
          >
            현재 미해결 backlog 가 없습니다.
          </p>
        ) : (
          <ul style="margin:8px 0 0;padding:0;list-style:none;">
            {carrySorted.map((b) => (
              <li
                style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:10px 0;border-bottom:1px dashed var(--border-subtle);"
              >
                <span style="font-size:12.5px;line-height:1.55;color:var(--fg-1);">
                  {b.text}
                  <span
                    style="display:block;font-family:var(--mono);font-size:10px;color:var(--fg-3);margin-top:2px;"
                  >
                    first · {formatDate(b.firstSeen)}
                  </span>
                </span>
                <AgeBadge age={b.age} />
              </li>
            ))}
          </ul>
        )
      }
    </div>

    {
      resolved.length > 0 && (
        <div>
          <span
            style="font-family:var(--mono);font-size:10px;color:var(--risk-low);letter-spacing:0.08em;text-transform:uppercase;"
          >
            ✓ resolved · {resolved.length}
          </span>
          <ul style="margin:8px 0 0;padding:0;list-style:none;">
            {resolved.map((r) => (
              <li
                style="padding:10px 0;border-bottom:1px dashed var(--border-subtle);font-size:12.5px;line-height:1.55;color:var(--fg-2);display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:start;"
              >
                <span style="color:var(--risk-low);">✓</span>
                <span>{r.text}</span>
                <span style="font-family:var(--mono);font-size:10px;color:var(--fg-3);">
                  {formatDate(r.resolvedDate)}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</dialog>

<style is:global>
  dialog#backlog-history-dialog::backdrop {
    background: rgba(10, 10, 14, 0.6);
    backdrop-filter: blur(2px);
  }
</style>

<script is:inline>
  (function () {
    const dialog = document.getElementById("backlog-history-dialog");
    if (!dialog) return;

    function open() {
      if (typeof dialog.showModal === "function") dialog.showModal();
      else dialog.setAttribute("open", "");
    }
    function close() {
      if (typeof dialog.close === "function") dialog.close();
      else dialog.removeAttribute("open");
    }

    document
      .querySelectorAll("[data-open-backlog]")
      .forEach((btn) => btn.addEventListener("click", open));
    document
      .querySelectorAll("[data-close-backlog]")
      .forEach((btn) => btn.addEventListener("click", close));
    // backdrop click closes
    dialog.addEventListener("click", (e) => {
      const rect = dialog.getBoundingClientRect();
      const inside =
        e.clientX >= rect.left &&
        e.clientX <= rect.right &&
        e.clientY >= rect.top &&
        e.clientY <= rect.bottom;
      if (!inside) close();
    });
  })();
</script>
