---
import RiskBadge from "./RiskBadge.astro";
import Sparkline from "./Sparkline.astro";
import Tag from "./Tag.astro";
import type { ChartSnapshot, Risk } from "../lib/reports";

interface Row {
  project: string;
  href: string;
  summary: string;
  risk: Risk;
  tags: string[];
  snapshots: ChartSnapshot[];
}
interface Props {
  rows: Row[];
}
const { rows } = Astro.props;
---

<div
  style="border:1px solid var(--border);border-radius:4px;overflow:hidden;background:var(--bg-1);"
>
  <div
    class="table-header"
    style="display:grid;grid-template-columns:240px 60px 80px 1fr 140px 90px 24px;padding:9px 14px;background:var(--bg-2);border-bottom:1px solid var(--border);font-family:var(--mono);font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--fg-3);gap:12px;align-items:center;"
  >
    <span>project</span>
    <span>risk</span>
    <span style="text-align:right;">prog</span>
    <span>trend</span>
    <span>tags</span>
    <span style="text-align:right;">reports</span>
    <span></span>
  </div>
  {
    rows.map((row, i) => {
      const last = row.snapshots[row.snapshots.length - 1];
      return (
        <a
          href={row.href}
          data-risk={row.risk}
          data-row
          data-chat-project={row.project}
          class="table-row"
          style={`display:grid;grid-template-columns:240px 60px 80px 1fr 140px 90px 24px;padding:12px 14px;gap:12px;align-items:center;border-bottom:${i < rows.length - 1 ? "1px solid var(--border)" : "none"};text-decoration:none;color:inherit;font-family:var(--sans);transition:background .12s;`}
        >
          <div
            style="display:flex;flex-direction:column;gap:2px;min-width:0;"
          >
            <span style="font-family:var(--mono);font-size:13px;font-weight:600;color:var(--fg-1);">
              {row.project}
            </span>
            <span class="table-row__chat-unread" data-chat-unread-badge hidden>
              <span aria-hidden="true"></span>
              새 메시지
            </span>
            <span style="font-size:11px;color:var(--fg-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              {row.summary}
            </span>
          </div>
          <RiskBadge level={row.risk} />
          <span style="font-family:var(--mono);font-size:13px;text-align:right;color:var(--fg-1);">
            {last ? `${last.progress}%` : "—"}
          </span>
          {row.snapshots.length >= 2 ? (
            <Sparkline
              values={row.snapshots.map((s) => s.progress)}
              width={160}
              height={28}
            />
          ) : (
            <span style="color:var(--fg-3);font-family:var(--mono);font-size:10px;">
              데이터 부족
            </span>
          )}
          <div style="display:flex;gap:4px;overflow:hidden;">
            {row.tags.slice(0, 2).map((t) => (
              <Tag>{t}</Tag>
            ))}
          </div>
          <span style="font-family:var(--mono);font-size:12px;color:var(--fg-2);text-align:right;">
            {row.snapshots.length}
          </span>
          <span style="color:var(--fg-3);">→</span>
        </a>
      );
    })
  }
</div>

<style>
  .table-row:hover {
    background: var(--bg-2);
  }

  .table-row[data-chat-unread="true"] {
    background: color-mix(in oklch, var(--risk-low) 6%, var(--bg-1));
  }

  .table-row__chat-unread {
    display: inline-flex;
    width: max-content;
    align-items: center;
    gap: 5px;
    margin-top: 2px;
    padding: 2px 6px;
    border: 1px solid color-mix(in oklch, var(--risk-low) 48%, var(--border));
    border-radius: 999px;
    background: color-mix(in oklch, var(--risk-low) 10%, var(--bg-1));
    color: var(--risk-low);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    line-height: 1.2;
  }

  .table-row__chat-unread[hidden] {
    display: none !important;
  }

  .table-row__chat-unread span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--risk-low);
    animation: table-row-chat-unread-pulse 1.4s ease-out infinite;
  }

  @keyframes table-row-chat-unread-pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in oklch, var(--risk-low) 42%, transparent);
    }
    70% {
      box-shadow: 0 0 0 7px transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }
</style>
