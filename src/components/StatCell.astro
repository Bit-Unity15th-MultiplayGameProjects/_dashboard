---
/**
 * Home 상단 stat strip 의 한 셀.
 * 5칸 grid 안에서 마지막 셀은 right border 제거.
 */
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  dot?: string; // 색 dot (risk 색)
  last?: boolean;
}
const { label, value, sub, dot, last = false } = Astro.props;
---

<div
  style={`padding:14px 16px;border-right:${last ? "none" : "1px solid var(--border)"};display:flex;flex-direction:column;gap:4px;min-width:0;`}
>
  <span
    style="font-family:var(--mono);font-size:10px;letter-spacing:0.08em;color:var(--fg-3);text-transform:uppercase;display:inline-flex;align-items:center;gap:6px;"
  >
    {
      dot && (
        <span
          style={`width:6px;height:6px;border-radius:50%;background:${dot};`}
        />
      )
    }
    {label}
  </span>
  <span
    style="font-family:var(--mono);font-size:28px;font-weight:500;letter-spacing:-0.02em;color:var(--fg-1);"
  >
    {value}
  </span>
  {sub && <span style="font-size:11px;color:var(--fg-3);">{sub}</span>}
</div>
