---
interface Props {
  size?: number;
}
const { size = 22 } = Astro.props;
const inner = Math.max(8, Math.round(size * 0.55));
---

<div
  style={`width:${size}px;height:${size}px;border-radius:4px;background:var(--accent);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;`}
>
  <svg width={inner} height={inner} viewBox="0 0 12 12" aria-hidden="true">
    <rect x="1" y="1" width="4" height="4" fill="var(--accent-fg)"></rect>
    <rect x="7" y="1" width="4" height="4" fill="var(--accent-fg)" opacity="0.5"
    ></rect>
    <rect x="1" y="7" width="4" height="4" fill="var(--accent-fg)" opacity="0.5"
    ></rect>
    <rect x="7" y="7" width="4" height="4" fill="var(--accent-fg)"></rect>
  </svg>
</div>
