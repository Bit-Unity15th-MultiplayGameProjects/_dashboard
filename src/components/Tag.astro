---
interface Props {
  prefix?: string;
}
const { prefix = "#" } = Astro.props;
---

<span
  style="display:inline-flex;align-items:center;height:22px;padding:0 8px;border-radius:3px;background:var(--tag-bg);border:1px solid var(--border-subtle);color:var(--fg-2);font-family:var(--mono);font-size:11px;white-space:nowrap;"
>
  {prefix}<slot />
</span>
