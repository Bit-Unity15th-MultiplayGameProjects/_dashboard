---
interface Props {
  project: string;
  org: string;
  supabaseUrl?: string;
  supabaseAnonKey?: string;
  title?: string;
  eyebrow?: string;
  toggleLabel?: string;
  channelName?: string;
  placeholder?: string;
  accessHint?: string;
  unauthorizedMessage?: string;
  emptyMessage?: string;
  ownerStatus?: string;
  contributorStatus?: string;
  memberStatus?: string;
  ariaLabel?: string;
}

const {
  project,
  org,
  supabaseUrl = "",
  supabaseAnonKey = "",
  title = "강사 채팅",
  eyebrow = "Instructor channel",
  toggleLabel = "강사 채팅",
  channelName = project,
  placeholder = "강사에게 남길 메시지",
  accessHint = "프로젝트 contributor와 대시보드 소유자만 대화를 볼 수 있습니다.",
  unauthorizedMessage = `${org}/${project} contributor 또는 대시보드 소유자만 참여할 수 있습니다.`,
  emptyMessage = "아직 남겨진 대화가 없습니다.",
  ownerStatus = "대시보드 소유자 권한으로 연결되었습니다.",
  contributorStatus = "프로젝트 contributor 권한으로 연결되었습니다.",
  memberStatus = "organization member 권한으로 연결되었습니다.",
  ariaLabel = title,
} = Astro.props;
const configured = supabaseUrl.length > 0 && supabaseAnonKey.length > 0;
---

<aside
  class="project-chat"
  data-project-chat
  data-open="false"
  data-has-unread="false"
  data-project={project}
  data-org={org}
  data-supabase-url={supabaseUrl}
  data-supabase-anon-key={supabaseAnonKey}
  data-empty-message={emptyMessage}
  data-unauthorized-message={unauthorizedMessage}
  data-owner-status={ownerStatus}
  data-contributor-status={contributorStatus}
  data-member-status={memberStatus}
  aria-label={ariaLabel}
>
  <button
    type="button"
    class="project-chat__toggle"
    data-chat-toggle
    aria-expanded="false"
    aria-controls={`project-chat-panel-${project}`}
  >
    <span class="project-chat__toggle-icon" aria-hidden="true"></span>
    <span class="project-chat__toggle-copy">
      <span>{toggleLabel}</span>
      <small>{channelName}</small>
    </span>
    <span class="project-chat__unread-dot" data-chat-unread-dot aria-hidden="true"></span>
  </button>

  <div
    id={`project-chat-panel-${project}`}
    class="project-chat__panel"
    data-chat-panel
  >
    <div class="project-chat__header">
      <div>
        <p class="project-chat__eyebrow">{eyebrow}</p>
        <div class="project-chat__title-row">
          <h2>{title}</h2>
          <span class="project-chat__status" data-chat-status>
            {
              configured
                ? "GitHub 로그인 상태를 확인하는 중입니다."
                : "채팅 DB 설정이 아직 연결되지 않았습니다."
            }
          </span>
        </div>
      </div>
      <button type="button" class="project-chat__close" data-chat-close aria-label="채팅 닫기">
        ×
      </button>
    </div>

    <div class="project-chat__messages" data-chat-messages role="log" aria-live="polite">
      <p class="project-chat__empty">
        {accessHint}
      </p>
    </div>

    <form class="project-chat__form" data-chat-form>
      <textarea
        data-chat-input
        name="message"
        rows="3"
        maxlength="1200"
        placeholder={placeholder}
        disabled></textarea>
      <div class="project-chat__form-row">
        <div class="project-chat__account-row">
          <button type="button" data-chat-login>GitHub 로그인</button>
          <button type="button" data-chat-logout hidden>로그아웃</button>
        </div>
        <span data-chat-user class="project-chat__user">로그인 필요</span>
        <button type="submit" data-chat-send disabled>전송</button>
      </div>
    </form>
  </div>
</aside>

<script is:inline>
  (function () {
    const roots = document.querySelectorAll("[data-project-chat]");
    if (roots.length === 0) return;

    const SESSION_KEY = "bitunity_dashboard_chat_session_v1";
    const READ_STATE_KEY = "bitunity_dashboard_chat_reads_v1";
    const CHAT_READ_EVENT = "bitunity:chat-read-state";
    const MAX_MESSAGES = 120;

    function setText(el, text) {
      if (el) el.textContent = text;
    }

    function readSession() {
      try {
        const raw = localStorage.getItem(SESSION_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    }

    function writeSession(session) {
      const expiresAt =
        session.expires_at ||
        Math.floor(Date.now() / 1000) + Number(session.expires_in || 3600);
      localStorage.setItem(
        SESSION_KEY,
        JSON.stringify({ ...session, expires_at: expiresAt }),
      );
      return readSession();
    }

    function clearSession() {
      localStorage.removeItem(SESSION_KEY);
    }

    function normalizeChatKey(project) {
      return String(project || "").toLowerCase();
    }

    function readChatReads() {
      try {
        const raw = localStorage.getItem(READ_STATE_KEY);
        return raw ? JSON.parse(raw) : {};
      } catch {
        return {};
      }
    }

    function writeChatReads(reads) {
      try {
        localStorage.setItem(READ_STATE_KEY, JSON.stringify(reads));
      } catch {
        // localStorage can be unavailable in strict privacy modes.
      }
    }

    function getChatReadAt(project, login) {
      const byUser = readChatReads()[String(login || "").toLowerCase()] || {};
      return byUser[normalizeChatKey(project)] || "";
    }

    function setChatReadAt(project, login, readAt) {
      const userKey = String(login || "").toLowerCase();
      const projectKey = normalizeChatKey(project);
      if (!userKey || !projectKey || !readAt) return;
      const reads = readChatReads();
      reads[userKey] = { ...(reads[userKey] || {}), [projectKey]: readAt };
      writeChatReads(reads);
      window.dispatchEvent(
        new CustomEvent(CHAT_READ_EVENT, {
          detail: { project: projectKey, login: userKey, readAt },
        }),
      );
    }

    function latestCreatedAt(messages) {
      if (!Array.isArray(messages) || messages.length === 0) return "";
      return messages.reduce((latest, message) => {
        if (!message.created_at) return latest;
        if (!latest) return message.created_at;
        return new Date(message.created_at).getTime() >
          new Date(latest).getTime()
          ? message.created_at
          : latest;
      }, "");
    }

    function hasUnreadMessage(messages, project, login) {
      const readAt = getChatReadAt(project, login);
      if (!readAt || !Array.isArray(messages)) return false;
      const readTime = new Date(readAt).getTime();
      return messages.some((message) => {
        if (
          String(message.user_login || "").toLowerCase() ===
          String(login || "").toLowerCase()
        )
          return false;
        return new Date(message.created_at).getTime() > readTime;
      });
    }

    function cleanAuthHash() {
      const hash = window.location.hash ? window.location.hash.slice(1) : "";
      if (!hash) return null;

      const params = new URLSearchParams(hash);
      const accessToken = params.get("access_token");
      const refreshToken = params.get("refresh_token");
      const error = params.get("error_description") || params.get("error");

      if (accessToken && refreshToken) {
        const session = writeSession({
          access_token: accessToken,
          refresh_token: refreshToken,
          expires_in: Number(params.get("expires_in") || 3600),
          token_type: params.get("token_type") || "bearer",
        });
        window.history.replaceState(
          {},
          document.title,
          window.location.pathname + window.location.search,
        );
        return { session };
      }

      if (error) {
        window.history.replaceState(
          {},
          document.title,
          window.location.pathname + window.location.search,
        );
        return { error };
      }

      return null;
    }

    function githubLoginFromUser(user) {
      const meta = user && user.user_metadata ? user.user_metadata : {};
      return String(
        meta.user_name ||
          meta.preferred_username ||
          meta.login ||
          meta.nickname ||
          "",
      ).toLowerCase();
    }

    function buildHeaders(anonKey, session, extra) {
      return {
        apikey: anonKey,
        Authorization: `Bearer ${session.access_token}`,
        ...extra,
      };
    }

    function formatTime(iso) {
      try {
        return new Intl.DateTimeFormat("ko-KR", {
          timeZone: "Asia/Seoul",
          hour: "2-digit",
          minute: "2-digit",
        }).format(new Date(iso));
      } catch {
        return "";
      }
    }

    function createInitial(login) {
      return (login || "?").slice(0, 1).toUpperCase();
    }

    function renderMessages(listEl, messages, ownLogin, emptyMessage) {
      listEl.replaceChildren();
      if (messages.length === 0) {
        const empty = document.createElement("p");
        empty.className = "project-chat__empty";
        empty.textContent = emptyMessage;
        listEl.appendChild(empty);
        return;
      }

      const fragment = document.createDocumentFragment();
      for (const message of messages) {
        const item = document.createElement("article");
        item.className = "project-chat__message";
        const isOwn = message.user_login === ownLogin;
        if (isOwn) item.classList.add("is-own");

        const avatar = document.createElement("div");
        avatar.className = "project-chat__avatar";
        if (message.user_avatar_url) {
          const img = document.createElement("img");
          img.src = message.user_avatar_url;
          img.alt = "";
          img.loading = "lazy";
          avatar.appendChild(img);
        } else {
          avatar.textContent = createInitial(message.user_login);
        }

        const stack = document.createElement("div");
        stack.className = "project-chat__stack";

        if (!isOwn) {
          const name = document.createElement("span");
          name.className = "project-chat__name";
          name.textContent = message.user_name || message.user_login;
          stack.appendChild(name);
        }

        const body = document.createElement("div");
        body.className = "project-chat__bubble";

        const text = document.createElement("p");
        text.textContent = message.body;
        body.appendChild(text);

        const time = document.createElement("time");
        time.className = "project-chat__time";
        time.dateTime = message.created_at;
        time.textContent = formatTime(message.created_at);

        stack.append(body);
        if (isOwn) {
          item.append(time, stack);
        } else {
          item.append(avatar, stack, time);
        }
        fragment.appendChild(item);
      }
      listEl.appendChild(fragment);
      listEl.scrollTop = listEl.scrollHeight;
    }

    roots.forEach((root) => {
      const project = root.dataset.project || "";
      const org = root.dataset.org || "";
      const supabaseUrl = (root.dataset.supabaseUrl || "").replace(/\/$/, "");
      const anonKey = root.dataset.supabaseAnonKey || "";
      const emptyMessage =
        root.dataset.emptyMessage || "아직 남겨진 대화가 없습니다.";
      const unauthorizedMessage =
        root.dataset.unauthorizedMessage ||
        `${org}/${project} contributor 또는 대시보드 소유자만 참여할 수 있습니다.`;
      const ownerStatus =
        root.dataset.ownerStatus || "대시보드 소유자 권한으로 연결되었습니다.";
      const contributorStatus =
        root.dataset.contributorStatus ||
        "프로젝트 contributor 권한으로 연결되었습니다.";
      const memberStatus =
        root.dataset.memberStatus || "organization member 권한으로 연결되었습니다.";

      const toggleBtn = root.querySelector("[data-chat-toggle]");
      const closeBtn = root.querySelector("[data-chat-close]");
      const statusEl = root.querySelector("[data-chat-status]");
      const loginBtn = root.querySelector("[data-chat-login]");
      const logoutBtn = root.querySelector("[data-chat-logout]");
      const messagesEl = root.querySelector("[data-chat-messages]");
      const formEl = root.querySelector("[data-chat-form]");
      const inputEl = root.querySelector("[data-chat-input]");
      const sendBtn = root.querySelector("[data-chat-send]");
      const userEl = root.querySelector("[data-chat-user]");

      let session = null;
      let user = null;
      let login = "";
      let pollTimer = null;
      let currentMessages = [];
      let currentLatestMessageAt = "";

      function setUnread(hasUnread) {
        root.dataset.hasUnread = hasUnread ? "true" : "false";
        toggleBtn.title = hasUnread ? "새 메시지가 있습니다." : "";
      }

      function markCurrentMessagesRead() {
        if (!login) return;
        const readAt = currentLatestMessageAt || new Date().toISOString();
        setChatReadAt(project, login, readAt);
        setUnread(false);
      }

      function syncUnreadState() {
        if (!login) {
          setUnread(false);
          return;
        }
        if (!getChatReadAt(project, login)) {
          const baseline = currentLatestMessageAt || new Date().toISOString();
          setChatReadAt(project, login, baseline);
          setUnread(false);
          return;
        }
        setUnread(hasUnreadMessage(currentMessages, project, login));
      }

      function setOpen(open) {
        root.dataset.open = open ? "true" : "false";
        toggleBtn.setAttribute("aria-expanded", open ? "true" : "false");
        if (open) {
          markCurrentMessagesRead();
          window.setTimeout(() => {
            const activeInput = !inputEl.disabled ? inputEl : loginBtn;
            activeInput && activeInput.focus();
          }, 0);
        }
      }

      function setComposerEnabled(enabled) {
        inputEl.disabled = !enabled;
        sendBtn.disabled = !enabled;
      }

      function setLoggedOut(message) {
        session = null;
        user = null;
        login = "";
        clearSession();
        loginBtn.hidden = false;
        logoutBtn.hidden = true;
        setUnread(false);
        setComposerEnabled(false);
        setText(userEl, "로그인 필요");
        setText(statusEl, message || "GitHub 로그인이 필요합니다.");
      }

      async function refreshSession(current) {
        if (!current || !current.refresh_token) return null;
        const res = await fetch(
          `${supabaseUrl}/auth/v1/token?grant_type=refresh_token`,
          {
            method: "POST",
            headers: {
              apikey: anonKey,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ refresh_token: current.refresh_token }),
          },
        );
        if (!res.ok) return null;
        return writeSession(await res.json());
      }

      async function ensureSession() {
        const hashResult = cleanAuthHash();
        if (hashResult && hashResult.error) {
          setText(statusEl, `로그인 실패: ${hashResult.error}`);
        }

        let current = hashResult && hashResult.session ? hashResult.session : readSession();
        if (!current) return null;

        const expiresAt = Number(current.expires_at || 0);
        const now = Math.floor(Date.now() / 1000);
        if (expiresAt && expiresAt - now < 60) {
          current = await refreshSession(current);
        }
        return current;
      }

      async function api(path, options) {
        const res = await fetch(`${supabaseUrl}${path}`, {
          ...options,
          headers: buildHeaders(anonKey, session, options && options.headers),
        });
        if (!res.ok) {
          let detail = "";
          try {
            const payload = await res.json();
            detail = payload.message || payload.error_description || payload.error || "";
          } catch {
            detail = await res.text();
          }
          throw new Error(detail || `HTTP ${res.status}`);
        }
        if (res.status === 204) return null;
        const text = await res.text();
        return text ? JSON.parse(text) : null;
      }

      async function loadUser() {
        user = await api("/auth/v1/user", { method: "GET" });
        login = githubLoginFromUser(user);
        if (!login) throw new Error("GitHub login 정보를 읽을 수 없습니다.");
      }

      async function checkMembership() {
        const query = new URLSearchParams({
          select: "project,login,role",
          project: `eq.${project}`,
          limit: "1",
        });
        const rows = await api(`/rest/v1/project_chat_members?${query}`, {
          method: "GET",
        });
        return Array.isArray(rows) && rows.length > 0 ? rows[0] : null;
      }

      async function loadMessages() {
        const query = new URLSearchParams({
          select:
            "id,user_login,user_name,user_avatar_url,body,created_at",
          project: `eq.${project}`,
          deleted_at: "is.null",
          order: "created_at.desc",
          limit: String(MAX_MESSAGES),
        });
        const messages = await api(`/rest/v1/project_chat_messages?${query}`, {
          method: "GET",
        });
        const loadedMessages = Array.isArray(messages)
          ? [...messages].reverse()
          : [];
        renderMessages(
          messagesEl,
          loadedMessages,
          login,
          emptyMessage,
        );
        currentMessages = loadedMessages;
        currentLatestMessageAt = latestCreatedAt(currentMessages);
        if (root.dataset.open === "true") {
          markCurrentMessagesRead();
        } else {
          syncUnreadState();
        }
      }

      async function boot() {
        if (!supabaseUrl || !anonKey) {
          loginBtn.disabled = true;
          setComposerEnabled(false);
          setText(
            statusEl,
            "Supabase URL과 anon key가 배포 환경변수에 필요합니다.",
          );
          return;
        }

        try {
          const hasAuthHash = window.location.hash.includes("access_token=");
          session = await ensureSession();
          if (hasAuthHash) setOpen(true);
          if (!session) {
            setLoggedOut("GitHub 로그인 후 프로젝트 채팅을 사용할 수 있습니다.");
            return;
          }

          await loadUser();
          const member = await checkMembership();
          loginBtn.hidden = true;
          logoutBtn.hidden = false;

          if (!member) {
            setComposerEnabled(false);
            setText(userEl, login ? `@${login}` : "권한 없음");
            setText(
              statusEl,
              unauthorizedMessage,
            );
            messagesEl.replaceChildren();
            const empty = document.createElement("p");
            empty.className = "project-chat__empty";
            empty.textContent = "권한이 확인되면 대화 이력이 표시됩니다.";
            messagesEl.appendChild(empty);
            setUnread(false);
            return;
          }

          login = member.login || login;
          setText(userEl, `@${login}`);
          setText(
            statusEl,
            member.role === "owner"
              ? ownerStatus
              : member.role === "member"
                ? memberStatus
                : contributorStatus,
          );
          setComposerEnabled(true);
          await loadMessages();

          if (pollTimer) window.clearInterval(pollTimer);
          pollTimer = window.setInterval(() => {
            loadMessages().catch(() => {});
          }, 20000);
        } catch (err) {
          setLoggedOut(err && err.message ? err.message : "채팅 연결에 실패했습니다.");
        }
      }

      loginBtn.addEventListener("click", () => {
        if (!supabaseUrl) return;
        const target = new URL(`${supabaseUrl}/auth/v1/authorize`);
        target.searchParams.set("provider", "github");
        target.searchParams.set(
          "redirect_to",
          window.location.href.split("#")[0],
        );
        window.location.assign(target.toString());
      });

      toggleBtn.addEventListener("click", () => {
        setOpen(root.dataset.open !== "true");
      });

      closeBtn.addEventListener("click", () => {
        setOpen(false);
      });

      logoutBtn.addEventListener("click", () => {
        if (pollTimer) window.clearInterval(pollTimer);
        setLoggedOut("로그아웃되었습니다.");
      });

      inputEl.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" || event.shiftKey || event.ctrlKey) return;
        event.preventDefault();
        if (!sendBtn.disabled) {
          formEl.requestSubmit();
        }
      });

      formEl.addEventListener("submit", async (event) => {
        event.preventDefault();
        const body = inputEl.value.trim();
        if (!body || !session) return;

        sendBtn.disabled = true;
        try {
          await api("/rest/v1/project_chat_messages", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Prefer: "return=minimal",
            },
            body: JSON.stringify({ project, body }),
          });
          inputEl.value = "";
          await loadMessages();
        } catch (err) {
          setText(
            statusEl,
            err && err.message ? `전송 실패: ${err.message}` : "전송에 실패했습니다.",
          );
        } finally {
          sendBtn.disabled = false;
          setComposerEnabled(true);
          inputEl.focus();
        }
      });

      window.addEventListener("focus", () => {
        if (session && login) loadMessages().catch(() => {});
      });

      window.addEventListener("storage", (event) => {
        if (event.key === READ_STATE_KEY) syncUnreadState();
      });

      window.addEventListener(CHAT_READ_EVENT, (event) => {
        const detail = event.detail || {};
        if (
          detail.project === normalizeChatKey(project) &&
          detail.login === String(login || "").toLowerCase()
        ) {
          syncUnreadState();
        }
      });

      boot();
    });
  })();
</script>

<style is:global>
  .project-chat {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 70;
    width: min(570px, calc(100vw - 32px));
    pointer-events: none;
  }

  .project-chat > * {
    pointer-events: auto;
  }

  .project-chat__toggle {
    display: flex;
    width: 248px;
    min-height: 56px;
    margin-left: auto;
    align-items: center;
    gap: 10px;
    padding: 9px 13px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-1);
    color: var(--fg-1);
    cursor: pointer;
    box-shadow:
      0 14px 34px rgba(0, 0, 0, 0.16),
      0 2px 8px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.15s,
      border-color 0.15s,
      box-shadow 0.15s;
  }

  .project-chat__toggle:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow:
      0 18px 42px rgba(0, 0, 0, 0.18),
      0 3px 10px rgba(0, 0, 0, 0.08);
  }

  .project-chat__toggle-icon {
    position: relative;
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    border: 1px solid color-mix(in oklch, var(--accent) 42%, var(--border));
    border-radius: 50%;
    background: color-mix(in oklch, var(--accent) 13%, var(--bg-1));
  }

  .project-chat__toggle-icon::before,
  .project-chat__toggle-icon::after {
    position: absolute;
    content: "";
    background: var(--accent);
  }

  .project-chat__toggle-icon::before {
    left: 8px;
    top: 9px;
    width: 15px;
    height: 10px;
    border-radius: 7px;
  }

  .project-chat__toggle-icon::after {
    left: 17px;
    top: 17px;
    width: 6px;
    height: 6px;
    clip-path: polygon(0 0, 100% 0, 0 100%);
  }

  .project-chat__toggle-copy {
    min-width: 0;
    text-align: left;
  }

  .project-chat__toggle-copy span,
  .project-chat__toggle-copy small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-chat__toggle-copy span {
    color: var(--fg-1);
    font-size: 13px;
    font-weight: 700;
  }

  .project-chat__toggle-copy small {
    margin-top: 2px;
    color: var(--fg-3);
    font-family: var(--mono);
    font-size: 10px;
