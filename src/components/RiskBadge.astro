---
interface Props {
  level: "low" | "medium" | "high";
  size?: "sm" | "md" | "lg";
}

const { level, size = "sm" } = Astro.props;

const meta = {
  low: { dot: "var(--risk-low)", text: "LOW", label: "low risk" },
  medium: { dot: "var(--risk-med)", text: "MED", label: "medium risk" },
  high: { dot: "var(--risk-high)", text: "HIGH", label: "high risk" },
}[level];

const h = size === "lg" ? 24 : size === "md" ? 20 : 18;
const fs = size === "lg" ? 11 : 10;
---

<span
  role="status"
  aria-label={meta.label}
  style={`display:inline-flex;align-items:center;gap:6px;height:${h}px;padding:0 8px;border-radius:3px;background:var(--badge-bg);border:1px solid var(--border);font-family:var(--mono);font-size:${fs}px;font-weight:600;letter-spacing:0.08em;color:var(--fg-2);`}
>
  <span
    style={`width:6px;height:6px;border-radius:50%;background:${meta.dot};box-shadow:0 0 0 2px ${meta.dot}22;`}
  ></span>
  {meta.text}
</span>
