---
import Sparkline from "./Sparkline.astro";

interface Props {
  label: string;
  values: number[];
  latest: string;
  accent?: string;
  max?: number;
}
const {
  label,
  values,
  latest,
  accent = "var(--accent)",
  max,
} = Astro.props;
---

<div
  style="border:1px solid var(--border);border-radius:4px;background:var(--bg-1);padding:12px 14px;"
>
  <div
    style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px;gap:8px;"
  >
    <span
      style="font-family:var(--mono);font-size:10px;color:var(--fg-3);letter-spacing:0.08em;text-transform:uppercase;"
      >{label}</span
    >
    <span
      style="font-family:var(--mono);font-size:12px;color:var(--fg-1);"
      >{latest}</span
    >
  </div>
  <Sparkline values={values} width={200} height={42} accent={accent} fixedMax={max} />
</div>
