---
/**
 * 프로젝트 상세 상단의 통합 진행도 패널.
 * - 큰 progress (`N / 100`) + 진행도 막대
 * - 문서화 상태: Design / Technical / Spec 가로 막대 + N/10
 *
 * 시계열 추이는 페이지 하단의 SmallMultiple 들이 담당. 여기는 현재 시점 스냅샷에 집중.
 */
interface Props {
  progress: number; // 0-100
  scores: { design: number; technical: number; spec: number };
  /** 최신 리포트 시각 — "기준: ..." 라벨용 */
  updatedAt?: string;
}

const { progress, scores, updatedAt } = Astro.props;

function formatUpdated(iso: string): string {
  return new Date(iso).toLocaleString("ko-KR", {
    timeZone: "Asia/Seoul",
    dateStyle: "medium",
    timeStyle: "short",
  });
}

const docs = [
  { key: "design" as const, label: "Design" },
  { key: "technical" as const, label: "Technical" },
  { key: "spec" as const, label: "Spec" },
];

const pct = Math.max(0, Math.min(100, progress));
---

<section
  style="border:1px solid var(--border);border-radius:4px;background:var(--bg-1);padding:18px 20px;"
  aria-label="프로젝트 예상 진행도"
>
  <div
    style="display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:18px;flex-wrap:wrap;"
  >
    <h2
      style="font-size:14px;font-weight:600;margin:0;letter-spacing:-0.01em;color:var(--fg-1);"
    >
      프로젝트 예상 진행도
    </h2>
    {
      updatedAt && (
        <span style="font-family:var(--mono);font-size:11px;color:var(--fg-3);">
          기준: {formatUpdated(updatedAt)}
        </span>
      )
    }
  </div>

  <div style="margin-bottom:18px;">
    <div
      style="display:flex;align-items:baseline;gap:6px;margin-bottom:10px;"
    >
      <span
        style="font-family:var(--mono);font-size:30px;font-weight:600;letter-spacing:-0.02em;color:var(--fg-1);line-height:1;"
        >{progress}</span
      >
      <span
        style="font-family:var(--mono);font-size:14px;color:var(--fg-3);"
        >/ 100</span
      >
    </div>
    <div
      style="height:8px;background:var(--bar-bg);border-radius:2px;overflow:hidden;"
    >
      <div
        style={`height:100%;width:${pct}%;background:var(--accent);transition:width .6s cubic-bezier(.2,.8,.2,1);`}
      >
      </div>
    </div>
  </div>

  <div>
    <h3
      style="font-size:11px;font-weight:600;color:var(--fg-3);letter-spacing:0.06em;text-transform:uppercase;margin:0 0 10px;font-family:var(--mono);"
    >
      문서화 상태
    </h3>
    <div style="display:flex;flex-direction:column;gap:9px;">
      {
        docs.map((it) => {
          const v = scores[it.key];
          const w = Math.max(0, Math.min(100, (v / 10) * 100));
          return (
            <div
              style="display:grid;grid-template-columns:80px 1fr 44px;align-items:center;gap:14px;"
            >
              <span style="font-size:12.5px;color:var(--fg-2);">
                {it.label}
              </span>
              <div style="height:6px;background:var(--bar-bg);border-radius:1.5px;overflow:hidden;">
                <div
                  style={`height:100%;width:${w}%;background:var(--accent);`}
                />
              </div>
              <span style="font-family:var(--mono);font-size:11px;color:var(--fg-2);text-align:right;">
                {v}/10
              </span>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
