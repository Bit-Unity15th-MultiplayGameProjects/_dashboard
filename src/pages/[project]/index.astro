---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import RiskBadge from "../../components/RiskBadge.astro";
import ProgressPanel from "../../components/ProgressPanel.astro";
import TodoList from "../../components/TodoList.astro";
import BacklogHistoryDialog from "../../components/BacklogHistoryDialog.astro";
import { getProjectSummaries, type ProjectSummary } from "../../lib/reports";

export const getStaticPaths = (async () => {
  const projects = await getProjectSummaries();
  return projects.map((p) => ({
    params: { project: p.project },
    props: { summary: p },
  }));
}) satisfies GetStaticPaths;

interface Props {
  summary: ProjectSummary;
}

const { summary } = Astro.props;
const { project, reports } = summary;

const BASE = import.meta.env.BASE_URL;
const base = BASE.endsWith("/") ? BASE.slice(0, -1) : BASE;

const latest = reports[0]!;
const latestData = latest.entry.data;

const historyEntries = reports.map((r) => ({
  date: r.entry.data.date,
  slug: r.slug,
  backlogs: r.entry.data.backlogs ?? [],
  resolved: r.entry.data.resolved_from_backlog ?? [],
  summary: r.entry.data.summary,
}));

function reportHref(slug: string) {
  return `${base}/${project}/${slug}/`;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleString("ko-KR", {
    timeZone: "Asia/Seoul",
    dateStyle: "medium",
    timeStyle: "short",
  });
}
---

<Layout title={`${project} — 리포트 히스토리`}>
  <nav class="mb-6 text-sm">
    <a
      href={BASE}
      class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100"
    >
      ← 대시보드
    </a>
  </nav>

  <header class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">
      {project}
    </h1>
    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
      총 {reports.length}개의 리뷰 리포트 — 최신순
    </p>
  </header>

  <ProgressPanel
    progress={latestData.progress_estimate}
    scores={latestData.doc_scores}
    updatedAt={latestData.date}
  />

  <TodoList todos={latestData.todos ?? []} />

  <BacklogHistoryDialog
    history={historyEntries}
    projectPath={`${base}/${project}`}
  />

  <section>
    <h2
      class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4"
    >
      리포트 타임라인
    </h2>
    <ol class="relative border-l border-slate-200 dark:border-slate-800 ml-3">
      {
        reports.map((r) => {
          const d = r.entry.data;
          return (
            <li class="mb-6 ml-6">
              <span class="absolute -left-[7px] mt-2 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-white dark:bg-slate-900 ring-2 ring-slate-300 dark:ring-slate-700" />
              <a
                href={reportHref(r.slug)}
                class="block rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4 hover:border-slate-400 dark:hover:border-slate-600 transition"
              >
                <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
                  <time>{formatDate(d.date)}</time>
                  <span>·</span>
                  <span class="font-mono">{d.commit_range}</span>
                  <span>·</span>
                  <span>{d.commit_count} commits</span>
                  <span class="ml-auto">
                    <RiskBadge level={d.risk_level} size="sm" />
                  </span>
                </div>
                <p class="mt-2 text-sm text-slate-800 dark:text-slate-200">
                  {d.summary}
                </p>
                {d.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {d.tags.map((t) => (
                      <span class="inline-flex items-center rounded-md bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 text-[11px] px-2 py-0.5">
                        #{t}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          );
        })
      }
    </ol>
  </section>
</Layout>
