---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import StatCell from "../components/StatCell.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectTable from "../components/ProjectTable.astro";
import FilterTabs from "../components/FilterTabs.astro";
import ViewToggle from "../components/ViewToggle.astro";
import ProjectChat from "../components/ProjectChat.astro";
import ChatUnreadMarkers from "../components/ChatUnreadMarkers.astro";
import {
  getAllReports,
  getProjectSummaries,
  chronologicalSnapshots,
  lastCommitAt,
} from "../lib/reports";

const BASE = import.meta.env.BASE_URL;
const base = BASE.endsWith("/") ? BASE.slice(0, -1) : BASE;
const ORG = "Bit-Unity15th-MultiplayGameProjects";
const ORG_CHAT_KEY = "__organization__";
const chatSupabaseUrl = import.meta.env.PUBLIC_CHAT_SUPABASE_URL ?? "";
const chatSupabaseAnonKey = import.meta.env.PUBLIC_CHAT_SUPABASE_ANON_KEY ?? "";

const allReports = await getAllReports();
const projects = await getProjectSummaries();

const totalProjects = projects.length;
const totalReports = allReports.length;

const riskCounts = { low: 0, medium: 0, high: 0 };
for (const p of projects) {
  riskCounts[p.latest.entry.data.risk_level] += 1;
}
const filterCounts = { all: totalProjects, ...riskCounts };

const buildTime = new Date().toLocaleString("ko-KR", {
  timeZone: "Asia/Seoul",
  dateStyle: "short",
  timeStyle: "short",
});

function projectHref(project: string) {
  return `${base}/${project}/`;
}

const cards = projects.map((p) => ({
  project: p.project,
  href: projectHref(p.project),
  summary: p.latest.entry.data.summary,
  risk: p.latest.entry.data.risk_level,
  tags: p.latest.entry.data.tags,
  snapshots: chronologicalSnapshots(p),
  lastCommitAt: lastCommitAt(p),
}));
---

<Layout title="Bit-Unity15th Dashboard">
  <Header>
    <div
      slot="left"
      style="display:flex;align-items:center;gap:10px;font-family:var(--sans);"
    >
      <Logo />
      <span
        style="font-family:var(--mono);font-size:13px;font-weight:600;letter-spacing:-0.01em;color:var(--fg-1);"
        >Bit-Unity15th</span
      >
      <span style="color:var(--fg-3);font-size:13px;">/</span>
      <span style="font-size:13px;color:var(--fg-2);">dashboard</span>
    </div>
    <Fragment slot="right">
      <span>Last build · {buildTime}</span>
      <span
        style="display:inline-flex;align-items:center;gap:6px;padding:3px 8px;border:1px solid var(--border);border-radius:3px;"
      >
        <span
          style="width:6px;height:6px;border-radius:50%;background:var(--risk-low);animation:dash-pulse 2s infinite;"
        ></span>
        synced
      </span>
    </Fragment>
  </Header>

  <section
    style="padding:32px 24px 24px;max-width:1280px;margin:0 auto;"
  >
    <div
      style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px;gap:16px;flex-wrap:wrap;"
    >
      <div>
        <h1
          style="font-size:24px;font-weight:600;margin:0;letter-spacing:-0.02em;color:var(--fg-1);"
        >
          프로젝트 대시보드
        </h1>
        <p
          style="margin:6px 0 0;color:var(--fg-2);font-size:13px;line-height:1.6;"
        >
          {ORG} organization 내 {totalProjects}개
          프로젝트의 코드리뷰·진행도 리포트.
        </p>
      </div>
      <div
        style="font-family:var(--mono);font-size:11px;color:var(--fg-3);"
      >
        주간 스냅샷 · {totalReports} reports
      </div>
    </div>

    <div
      style="display:grid;grid-template-columns:repeat(5, minmax(0, 1fr));border:1px solid var(--border);border-radius:4px;overflow:hidden;background:var(--bg-1);"
      class="stat-strip"
    >
      <StatCell label="projects" value={totalProjects} sub="active repos" />
      <StatCell label="reports" value={totalReports} sub="accumulated" />
      <StatCell
        label="risk · low"
        value={riskCounts.low}
        dot="var(--risk-low)"
      />
      <StatCell
        label="risk · med"
        value={riskCounts.medium}
        dot="var(--risk-med)"
      />
      <StatCell
        label="risk · high"
        value={riskCounts.high}
        dot="var(--risk-high)"
        last
      />
    </div>
  </section>

  <section
    style="padding:0 24px 48px;max-width:1280px;margin:0 auto;"
  >
    {
      projects.length === 0 ? (
        <div
          style="border:1px dashed var(--border);border-radius:4px;padding:48px 24px;text-align:center;color:var(--fg-3);font-family:var(--mono);font-size:12px;"
        >
          아직 수집된 리포트가 없습니다.
        </div>
      ) : (
        <>
          <div
            style="display:flex;align-items:center;margin-bottom:14px;gap:8px;flex-wrap:wrap;"
          >
            <h2
              style="font-size:13px;font-weight:600;margin:0;letter-spacing:0.02em;color:var(--fg-1);"
            >
              프로젝트{" "}
              <span
                data-visible-count
                style="color:var(--fg-3);font-family:var(--mono);font-weight:400;"
              >
                ({cards.length})
              </span>
            </h2>
            <div
              style="margin-left:auto;display:flex;gap:8px;align-items:center;flex-wrap:wrap;"
            >
              <FilterTabs counts={filterCounts} />
              <ViewToggle />
            </div>
          </div>

          <div
            data-view-pane="grid"
            class="project-grid"
            style="display:grid;grid-template-columns:repeat(2, minmax(0, 1fr));gap:12px;"
          >
            {cards.map((c) => (
              <ProjectCard
                project={c.project}
                href={c.href}
                summary={c.summary}
                risk={c.risk}
                tags={c.tags}
                snapshots={c.snapshots}
                lastCommitAt={c.lastCommitAt}
              />
            ))}
          </div>

          <div data-view-pane="table" style="display:none;">
            <ProjectTable rows={cards} />
          </div>

          <p
            data-empty-msg
            style="display:none;border:1px dashed var(--border);border-radius:4px;padding:32px 24px;text-align:center;color:var(--fg-3);font-family:var(--mono);font-size:12px;margin-top:12px;"
          >
            해당 risk 레벨의 프로젝트가 없습니다.
          </p>
        </>
      )
    }
  </section>

  <Footer />

  <ProjectChat
    project={ORG_CHAT_KEY}
    org={ORG}
    supabaseUrl={chatSupabaseUrl}
    supabaseAnonKey={chatSupabaseAnonKey}
    title="조직 채팅"
    eyebrow="Organization channel"
    toggleLabel="조직 채팅"
    channelName={ORG}
    placeholder="조직 채팅 메시지"
    accessHint="organization member만 대화를 볼 수 있습니다."
    unauthorizedMessage={`${ORG} organization member만 참여할 수 있습니다.`}
    emptyMessage="아직 조직 채팅 메시지가 없습니다."
    ownerStatus="대시보드 소유자 권한으로 연결되었습니다."
    memberStatus="organization member 권한으로 연결되었습니다."
    contributorStatus="organization member 권한으로 연결되었습니다."
    ariaLabel="조직 채팅"
  />

  <ChatUnreadMarkers
    supabaseUrl={chatSupabaseUrl}
    supabaseAnonKey={chatSupabaseAnonKey}
  />
</Layout>

<style is:global>
  @media (max-width: 720px) {
    .stat-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
    .project-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script is:inline>
  (function () {
    let view = "grid";
    let filter = "all";

    const apply = () => {
      // toggle view panes
      document.querySelectorAll("[data-view-pane]").forEach((el) => {
        el.style.display =
          el.dataset.viewPane === view
            ? el.dataset.viewPane === "grid"
              ? "grid"
              : "block"
            : "none";
      });
      // filter cards / rows
      let visible = 0;
      document
        .querySelectorAll("[data-card], [data-row]")
        .forEach((el) => {
          const isCard = el.hasAttribute("data-card");
          if (
            (view === "grid" && !isCard) ||
            (view === "table" && isCard)
          )
            return;
          const matches = filter === "all" || el.dataset.risk === filter;
          el.style.display = matches ? (isCard ? "flex" : "grid") : "none";
          if (matches) visible += 1;
        });
      const counter = document.querySelector("[data-visible-count]");
      if (counter) counter.textContent = `(${visible})`;
      const empty = document.querySelector("[data-empty-msg]");
      if (empty) empty.style.display = visible === 0 ? "block" : "none";
      // pressed states
      document.querySelectorAll("[data-filter-btn]").forEach((b) => {
        const active = b.dataset.filterBtn === filter;
        b.setAttribute("aria-pressed", active ? "true" : "false");
        b.style.background = active ? "var(--bg-2)" : "var(--bg)";
        b.style.color = active ? "var(--fg-1)" : "var(--fg-2)";
      });
      document.querySelectorAll("[data-view-btn]").forEach((b) => {
        const active = b.dataset.viewBtn === view;
        b.setAttribute("aria-pressed", active ? "true" : "false");
        b.style.background = active ? "var(--bg-2)" : "var(--bg)";
        b.style.color = active ? "var(--fg-1)" : "var(--fg-2)";
      });
    };

    document.querySelectorAll("[data-filter-btn]").forEach((b) => {
      b.addEventListener("click", () => {
        filter = b.dataset.filterBtn;
        apply();
      });
    });
    document.querySelectorAll("[data-view-btn]").forEach((b) => {
      b.addEventListener("click", () => {
        view = b.dataset.viewBtn;
        apply();
      });
    });
  })();
</script>
