---
import Layout from "../layouts/Layout.astro";
import StatCard from "../components/StatCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getAllReports, getProjectSummaries } from "../lib/reports";

const BASE = import.meta.env.BASE_URL;

const allReports = await getAllReports();
const projects = await getProjectSummaries();

const totalProjects = projects.length;
const totalReports = allReports.length;

const riskCounts = { low: 0, medium: 0, high: 0 };
for (const p of projects) {
  riskCounts[p.latest.entry.data.risk_level] += 1;
}

function projectHref(project: string) {
  // BASE already starts with `/` (e.g. "/_dashboard"); ensure no double slash.
  const base = BASE.endsWith("/") ? BASE.slice(0, -1) : BASE;
  return `${base}/${project}/`;
}
---

<Layout title="Bit-Unity15th Dashboard">
  <section class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">
      수강생 프로젝트 대시보드
    </h1>
    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
      Bit-Unity15th-MultiplayGameProjects organization 내 수강생 repo들의
      코드리뷰/진행도 리포트를 주기적으로 수집합니다.
    </p>
  </section>

  <section
    class="grid grid-cols-2 sm:grid-cols-5 gap-3 sm:gap-4 mb-10"
    aria-label="전체 통계"
  >
    <StatCard label="프로젝트" value={totalProjects} />
    <StatCard label="리포트" value={totalReports} />
    <StatCard label="Low risk" value={riskCounts.low} accent="emerald" />
    <StatCard label="Medium risk" value={riskCounts.medium} accent="amber" />
    <StatCard label="High risk" value={riskCounts.high} accent="rose" />
  </section>

  <section>
    <div class="flex items-end justify-between mb-4">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
        프로젝트
      </h2>
      <span class="text-xs text-slate-500 dark:text-slate-400">
        최근 업데이트순
      </span>
    </div>

    {
      projects.length === 0 ? (
        <div class="rounded-xl border border-dashed border-slate-300 dark:border-slate-700 p-12 text-center text-slate-500">
          아직 수집된 리포트가 없습니다.
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((p) => (
            <ProjectCard
              project={p.project}
              href={projectHref(p.project)}
              date={p.latest.entry.data.date}
              summary={p.latest.entry.data.summary}
              risk={p.latest.entry.data.risk_level}
              tags={p.latest.entry.data.tags}
              reportCount={p.reports.length}
            />
          ))}
        </div>
      )
    }
  </section>
</Layout>
